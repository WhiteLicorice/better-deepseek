{
  "manifest_version": 3,
  "name": "Better DeepSeek",
  "version": "0.1.6",
  "description": "Enhanced UX layer for DeepSeek with hidden prompts, tools, memory, document generation, and long-work packaging.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://codeload.github.com/*",
    "https://api.github.com/*",
    "https://api-docs.deepseek.com/*",
    "https://raw.githubusercontent.com/*",
    "https://publish.twitter.com/*",
    "https://www.youtube.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://pyscript.net/*"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js",
        "sandbox.html",
        "sandbox.js",
        "static/loading/*.svg",
        "static/web-fetch-permission.html",
        "static/web-fetch-permission.js"
      ],
      "matches": ["https://chat.deepseek.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "action": {
    "default_title": "Better DeepSeek"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups; script-src 'self' 'unsafe-eval' 'unsafe-inline' blob:; object-src 'self'"
  }
}
